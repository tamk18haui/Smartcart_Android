<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="SmartCart"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.SmartCartAndroid">

        <!-- Firebase Notification Channel -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="smartcart_notification_channel" />

        <!-- Firebase Messaging Service -->
        <service
            android:name=".common.notification.SmartCartFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Điều hướng role sau đăng nhập -->
        <activity
            android:name=".navigation.RoleRouterActivity"
            android:exported="false" />

        <!-- ================= AUTH ================= -->

        <activity
            android:name=".auth.register.RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".auth.login.LoginActivity"
            android:exported="false" />

        <!-- ================= CHAT ================= -->

        <activity
            android:name=".chat.ChatListActivity"
            android:exported="false" />

        <activity
            android:name=".chat.ChatRoomActivity"
            android:exported="false" />

        <!-- ================= BUYER ================= -->

        <activity
            android:name=".buyer.main.BuyerMainActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.product.ProductDetailActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.product.ProductReviewsActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.account.AccountActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.account.profile.ProfileActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.address.AddressActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.address.AddressFormActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.notification.NotificationActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.support.SupportCenterActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.cart.CartActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.order.OrderHistoryActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.order.OrderDetailActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.review.ReviewActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.category.CategoryActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.category.CategoryProductListActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.search.SearchProductActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.search.AiImageSearchActivity"
            android:exported="false" />

        <activity
            android:name=".buyer.checkout.CheckoutActivity"
            android:exported="false" />

        <!-- ================= SELLER ================= -->

        <activity
            android:name=".seller.main.SellerHomeActivity"
            android:exported="false" />

        <!-- Seller Notification -->
        <activity
            android:name=".seller.notification.SellerNotificationActivity"
            android:exported="false" />

        <!-- Seller Product -->
        <activity
            android:name=".seller.product.AddProductActivity"
            android:exported="false" />

        <activity
            android:name=".seller.product.SellerProductDetailActivity"
            android:exported="false" />

        <activity
            android:name=".seller.product.BrandPickerActivity"
            android:exported="false" />

        <activity
            android:name=".seller.product.CategoryPickerActivity"
            android:exported="false" />

        <activity
            android:name=".seller.product.ShippingActivity"
            android:exported="false" />

        <activity
            android:name=".seller.product.VariantEditorActivity"
            android:exported="false" />

        <!-- Seller Review -->
        <activity
            android:name=".seller.review.SellerProductReviewsActivity"
            android:exported="false" />

        <!-- Seller Shop -->
        <activity
            android:name=".seller.shop.SellerShopInfoActivity"
            android:exported="false" />

        <!-- Seller Wallet -->
        <activity
            android:name=".seller.wallet.SellerWalletActivity"
            android:exported="false" />

        <activity
            android:name=".seller.wallet.RevenueStatisticActivity"
            android:exported="false" />

        <!-- Seller Orders -->
        <activity
            android:name=".seller.order.SellerOrderDetailActivity"
            android:exported="false" />

        <activity
            android:name=".seller.order.ShippingLabelActivity"
            android:exported="false" />

        <!-- Seller Voucher -->
        <activity
            android:name=".seller.voucher.SellerVoucherActivity"
            android:exported="false" />

        <activity
            android:name=".seller.voucher.CreateVoucherActivity"
            android:exported="false" />

        <!-- ================= MAIN ================= -->

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

    </application>

</manifest>