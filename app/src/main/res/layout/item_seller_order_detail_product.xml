<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="116dp"
    android:layout_marginBottom="10dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp"
    android:background="@drawable/bg_seller_card">

    <ImageView
        android:id="@+id/imgProduct"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_image_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên sản phẩm"
            android:textColor="@color/seller_text_primary"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/txtVariant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Màu: Đen"
            android:textColor="@color/seller_text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/txtQuantity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Số lượng: x1"
            android:textColor="@color/seller_text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="890,000đ"
        android:textColor="@color/seller_primary_dark"
        android:textStyle="bold"
        android:textSize="15sp" />

</LinearLayout>


