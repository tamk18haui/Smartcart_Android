<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="112dp"
    android:layout_marginBottom="12dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/bg_seller_card">

    <ImageView
        android:id="@+id/imgProduct"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_image_placeholder" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên sản phẩm"
            android:textColor="@color/seller_text_primary"
            android:textStyle="bold"
            android:textSize="16sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/txtVariant"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="Màu: Đen"
            android:textSize="12sp"
            android:textColor="@color/seller_text_secondary"
            android:background="@drawable/bg_seller_chip_soft" />

        <TextView
            android:id="@+id/txtStock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tồn kho: 48"
            android:textColor="@color/seller_primary_dark"
            android:textStyle="bold"
            android:textSize="15sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnMinus"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="10dp"
        android:background="@drawable/bg_seller_button_outline"
        android:src="@drawable/ic_minus" />

    <TextView
        android:id="@+id/txtQuantity"
        android:layout_width="44dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="48"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/seller_text_primary" />

    <ImageButton
        android:id="@+id/btnPlus"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="10dp"
        android:background="@drawable/bg_seller_button_primary"
        android:src="@drawable/ic_plus" />

</LinearLayout>
