<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tạo yêu cầu rút tiền"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/edtWithdrawAmount"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_address_input"
        android:hint="Số tiền rút, tối thiểu 10000"
        android:inputType="number"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/edtBankName"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_address_input"
        android:hint="Tên ngân hàng"
        android:inputType="textCapWords"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/edtBankAccountNumber"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_address_input"
        android:hint="Số tài khoản"
        android:inputType="number"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/edtBankAccountHolder"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_address_input"
        android:hint="Tên chủ tài khoản"
        android:inputType="textCapCharacters"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/edtSellerNote"
        android:layout_width="match_parent"
        android:layout_height="86dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_address_input"
        android:gravity="top"
        android:hint="Ghi chú cho admin nếu có"
        android:inputType="textMultiLine"
        android:padding="12dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />
</LinearLayout>
