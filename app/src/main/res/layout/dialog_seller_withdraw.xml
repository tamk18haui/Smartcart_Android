<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:isScrollContainer="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tạo yêu cầu rút tiền"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/edtWithdrawAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_address_input"
                android:hint="Số tiền rút (Tối thiểu 10.000đ)"
                android:inputType="number"
                android:maxLines="1"
                android:minHeight="52dp"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtBankName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_address_input"
                android:hint="Tên ngân hàng"
                android:inputType="textCapWords"
                android:maxLines="1"
                android:minHeight="52dp"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtBankAccountNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_address_input"
                android:hint="Số tài khoản"
                android:inputType="number"
                android:maxLines="1"
                android:minHeight="52dp"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtBankAccountHolder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_address_input"
                android:hint="Tên chủ tài khoản"
                android:inputType="textCapCharacters"
                android:maxLines="1"
                android:minHeight="52dp"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/edtSellerNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_address_input"
                android:gravity="top|start"
                android:hint="Ghi chú cho admin nếu có"
                android:inputType="textMultiLine|textCapSentences"
                android:minHeight="96dp"
                android:padding="16dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>