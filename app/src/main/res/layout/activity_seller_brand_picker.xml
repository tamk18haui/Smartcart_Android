<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_seller_screen"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/brand_primary"
            android:textSize="34sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Tạo thương hiệu"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="44dp"
            android:layout_height="match_parent" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <EditText
            android:id="@+id/edtBrandSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_seller_input_soft"
            android:hint="Tìm kiếm hoặc nhập thương hiệu"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:singleLine="true"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint" />

        <Button
            android:id="@+id/btnSearchBrand"
            android:layout_width="92dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_seller_button_primary"
            android:text="Tìm"
            android:textAllCaps="false"
            android:textColor="@color/text_white" />
    </LinearLayout>

    <Button
        android:id="@+id/btnUseCustomBrand"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_seller_button_outline"
        android:text="Dùng tên đang nhập nếu chưa có"
        android:textAllCaps="false"
        android:textColor="@color/brand_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/brandListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>


