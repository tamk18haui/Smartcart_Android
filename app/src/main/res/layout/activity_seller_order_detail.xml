<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/seller_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:background="@color/seller_primary_dark">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="9dp"
            android:src="@drawable/ic_back"
            android:tint="@color/seller_text_white" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chi tiết đơn hàng"
            android:textColor="@color/seller_text_white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="132dp"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_seller_card">

                <TextView
                    android:id="@+id/txtStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ĐANG GIAO"
                    android:textStyle="bold"
                    android:textColor="@color/success"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:background="@drawable/bg_seller_chip_soft" />

                <TextView
                    android:id="@+id/txtOrderCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="#ORD-12344"
                    android:textColor="@color/seller_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="09:15 24/05/2024"
                    android:textColor="@color/seller_text_secondary"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_seller_card">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Thông tin người nhận"
                    android:textColor="@color/seller_text_primary"
                    android:textStyle="bold"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/txtReceiverName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên khách hàng"
                    android:textColor="@color/seller_text_primary"
                    android:textSize="16sp"
                    android:layout_marginTop="14dp" />

                <TextView
                    android:id="@+id/txtReceiverPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Số điện thoại"
                    android:textColor="@color/seller_text_primary"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/seller_divider"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Địa chỉ giao hàng:"
                    android:textColor="@color/seller_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Địa chỉ"
                    android:textColor="@color/seller_text_primary"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_seller_card">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Lịch sử hành trình"
                    android:textColor="@color/seller_text_primary"
                    android:textStyle="bold"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/txtTimeline1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đã đặt hàng"
                    android:textColor="@color/seller_text_primary"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/txtTimeline2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Shop đã xác nhận"
                    android:textColor="@color/seller_text_primary"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/txtTimeline3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đang giao"
                    android:textColor="@color/seller_primary_dark"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/txtTimeline4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chờ hoàn thành"
                    android:textColor="@color/seller_text_secondary"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Sản phẩm"
                android:textColor="@color/seller_text_primary"
                android:textStyle="bold"
                android:textSize="20sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOrderItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_seller_card">

                <TextView
                    android:id="@+id/txtSubtotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="890,000đ"
                    android:textColor="@color/seller_text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/txtShippingFee"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="25,000đ"
                    android:textColor="@color/seller_text_primary"
                    android:textSize="16sp"
                    android:layout_marginTop="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@color/seller_divider" />

                <TextView
                    android:id="@+id/txtTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="915,000đ"
                    android:textColor="@color/seller_primary_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:padding="14dp"
        android:orientation="horizontal"
        android:background="@color/seller_surface">

        <TextView
            android:id="@+id/btnContactBuyer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Liên hệ người mua"
            android:textStyle="bold"
            android:textColor="@color/seller_primary_dark"
            android:background="@drawable/bg_seller_button_outline" />

        <TextView
            android:id="@+id/btnUpdateStatus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text="Cập nhật trạng thái"
            android:textStyle="bold"
            android:textColor="@color/seller_text_white"
            android:background="@drawable/bg_seller_button_primary" />
    </LinearLayout>

</LinearLayout>
