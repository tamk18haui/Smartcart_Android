    <color name="brand_gradient_center">#2563EB</color>
    <color name="brand_gradient_end">#2563EB</color>


    <!-- ========================= -->
    <!-- Commerce Accent: Coral Red -->
    <!-- Dùng cho giá tiền, sale, lỗi, cảnh báo mạnh -->
    <!-- ========================= -->
    <color name="price_red">#F43F5E</color>
    <color name="danger">#F43F5E</color>
    <color name="danger_light">#FFF1F2</color>


    <!-- ========================= -->
    <!-- Trust Accent: Emerald Green -->
    <!-- Dùng cho voucher hợp lệ, freeship, thành công -->
