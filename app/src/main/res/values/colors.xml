<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ========================================================= -->
    <!-- SMARTCART MODERN COMMERCE COLOR SYSTEM -->
    <!-- Navy Blue + Emerald + Coral + Violet -->
    <!-- Không dùng gradient, nhưng vẫn giữ tên gradient để không vỡ drawable cũ -->
    <!-- ========================================================= -->


    <!-- ========================= -->
    <!-- Primary Brand: Modern Navy Blue -->
    <!-- Dùng cho header, nút chính, icon active, bottom nav -->
    <!-- ========================= -->
    <color name="brand_primary">#2563EB</color>
    <color name="brand_primary_dark">#1D4ED8</color>
    <color name="brand_primary_light">#EFF6FF</color>
    <color name="brand_secondary">#38BDF8</color>

    <!-- Giữ tên để không lỗi XML cũ, nhưng không còn phối gradient nữa -->
